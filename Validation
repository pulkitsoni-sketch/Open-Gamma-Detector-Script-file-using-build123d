"""
validate.py — Volumetric & Symmetric-Difference Analysis
Compares original STL files against rebuilt STL files.

Meshes are centre-aligned and the best-matching orientation among all 24
axis-aligned rotations (including Z-flips) is found before computing
Hausdorff distance and symmetric difference.

INSTALL (run once):
    pip3 install trimesh manifold3d numpy

RUN:
    /usr/local/bin/python3 "/Users/softage/Desktop/Visual Studio/validate.py"
"""

import os
import struct
import numpy as np

try:
    import trimesh
    HAS_TRIMESH = True
except ImportError:
    HAS_TRIMESH = False

GREEN  = "\033[92m"
RED    = "\033[91m"
YELLOW = "\033[93m"
CYAN   = "\033[96m"
RESET  = "\033[0m"
BOLD   = "\033[1m"

# ─────────────────────────────────────────────────────────────
# RAW STL UTILITIES
# ─────────────────────────────────────────────────────────────

def is_binary_stl(path):
    with open(path, 'rb') as f:
        header = f.read(80)
    return not (header[:5] == b'solid' and header[5:6] in (b' ', b'\n', b'\r'))

def get_all_vertices(path):
    pts = []
    if is_binary_stl(path):
        with open(path, 'rb') as f:
            f.read(80)
            n = struct.unpack('<I', f.read(4))[0]
            for _ in range(n):
                data = struct.unpack('<12fH', f.read(50))
                pts.extend([data[3:6], data[6:9], data[9:12]])
    else:
        with open(path, 'r', errors='ignore') as f:
            for line in f:
                s = line.strip()
                if s.startswith('vertex'):
                    p = s.split()
                    pts.append((float(p[1]), float(p[2]), float(p[3])))
    return np.array(pts, dtype=np.float64)

def get_triangles(path):
    tris = []
    if is_binary_stl(path):
        with open(path, 'rb') as f:
            f.read(80)
            n = struct.unpack('<I', f.read(4))[0]
            for _ in range(n):
                data = struct.unpack('<12fH', f.read(50))
                tris.append([data[3:6], data[6:9], data[9:12]])
    else:
        verts = []
        with open(path, 'r', errors='ignore') as f:
            for line in f:
                s = line.strip()
                if s.startswith('vertex'):
                    p = s.split()
                    verts.append([float(p[1]), float(p[2]), float(p[3])])
        for i in range(0, len(verts) - 2, 3):
            tris.append([verts[i], verts[i+1], verts[i+2]])
    return np.array(tris, dtype=np.float64)

def volume_from_stl(path):
    total = 0.0
    for tri in get_triangles(path):
        v1, v2, v3 = tri
        total += np.dot(v1, np.cross(v2, v3)) / 6.0
    return abs(total)

def triangle_count(path):
    if is_binary_stl(path):
        with open(path, 'rb') as f:
            f.read(80)
            return struct.unpack('<I', f.read(4))[0]
    with open(path, 'r', errors='ignore') as f:
        return sum(1 for l in f if l.strip().startswith('facet normal'))

def bbox(path):
    pts = get_all_vertices(path)
    return pts.min(axis=0), pts.max(axis=0)

def surface_area_from_stl(path):
    total = 0.0
    for tri in get_triangles(path):
        v1, v2, v3 = tri
        total += np.linalg.norm(np.cross(v2 - v1, v3 - v1)) / 2.0
    return total

def centre(pts):
    return pts - (pts.min(axis=0) + pts.max(axis=0)) / 2.0

# ─────────────────────────────────────────────────────────────
# ALL 24 PROPER AXIS-ALIGNED ROTATION MATRICES
# Generated by enumerating all signed permutation matrices with det=+1
# This guarantees every possible 90°-step orientation is covered,
# including all Z-flips, X-flips, and Y-flips.
# ─────────────────────────────────────────────────────────────

def _all_24_rotations():
    from itertools import permutations, product
    rots = []
    for perm in permutations([0, 1, 2]):
        for signs in product([1, -1], repeat=3):
            R = np.zeros((3, 3))
            for i, j in enumerate(perm):
                R[i, j] = signs[i]
            if round(np.linalg.det(R)) == 1:   # proper rotation only (det=+1)
                rots.append(R)
    return rots

ALL_24_ROTS = _all_24_rotations()

# ─────────────────────────────────────────────────────────────
# ORIENTATION SEARCH
# ─────────────────────────────────────────────────────────────

def best_orientation(pts_a_raw, pts_b_raw, subsample=1000):
    """
    Centre both clouds, then search all 24 axis-aligned rotations of pts_b
    to find the one minimising mean nearest-neighbour distance to pts_a.
    Returns the full rotated+centred pts_b at the best orientation.
    """
    rng  = np.random.default_rng(0)
    pa   = centre(pts_a_raw)
    pb   = centre(pts_b_raw)

    ia = rng.choice(len(pa), min(subsample, len(pa)),   replace=False)
    ib = rng.choice(len(pb), min(subsample, len(pb)),   replace=False)
    pa_s = pa[ia]
    pb_s = pb[ib]

    best_d = np.inf
    best_R = np.eye(3)

    for R in ALL_24_ROTS:
        pb_rot = (R @ pb_s.T).T
        # mean of per-point minimum distances (cheap proxy for Hausdorff)
        diff = pa_s[:, None, :] - pb_rot[None, :, :]
        d    = np.sqrt((diff**2).sum(axis=2)).min(axis=1).mean()
        if d < best_d:
            best_d = d
            best_R = R

    return (best_R @ pb.T).T, best_R   # full rotated cloud + winning matrix

# ─────────────────────────────────────────────────────────────
# HAUSDORFF DISTANCE  (orientation-aware)
# ─────────────────────────────────────────────────────────────

def hausdorff_distance(path_a, path_b, sample_count=5000):
    pts_a = get_all_vertices(path_a)
    pts_b = get_all_vertices(path_b)

    pa = centre(pts_a)
    pb_rot, _ = best_orientation(pts_a, pts_b)

    rng = np.random.default_rng(42)
    if len(pa)     > sample_count: pa     = pa    [rng.choice(len(pa),     sample_count, replace=False)]
    if len(pb_rot) > sample_count: pb_rot = pb_rot[rng.choice(len(pb_rot), sample_count, replace=False)]

    def directed(src, tgt):
        max_min, chunk = 0.0, 500
        for i in range(0, len(src), chunk):
            s     = src[i:i+chunk]
            dists = np.sqrt(((s[:, None] - tgt[None])**2).sum(axis=2))
            max_min = max(max_min, dists.min(axis=1).max())
        return max_min

    return max(directed(pa, pb_rot), directed(pb_rot, pa))

# ─────────────────────────────────────────────────────────────
# SYMMETRIC DIFFERENCE  (orientation-aware, requires trimesh)
# ─────────────────────────────────────────────────────────────

def symmetric_difference(orig_path, rebuilt_path):
    if not HAS_TRIMESH:
        return None, None, "trimesh not installed"
    try:
        a = trimesh.load(orig_path,    force='mesh')
        b = trimesh.load(rebuilt_path, force='mesh')

        # Centre both
        a.apply_translation(-a.bounding_box.center_mass)
        b.apply_translation(-b.bounding_box.center_mass)

        # Find best rotation for b to match a
        _, best_R = best_orientation(np.array(a.vertices), np.array(b.vertices))

        T = np.eye(4)
        T[:3, :3] = best_R
        b.apply_transform(T)

        if not a.is_watertight:
            trimesh.repair.fill_holes(a)
        if not b.is_watertight:
            trimesh.repair.fill_holes(b)

        if not a.is_watertight or not b.is_watertight:
            return None, None, "Not all meshes are volumes (open shell)"

        a_minus_b = trimesh.boolean.difference([a, b], engine='manifold')
        b_minus_a = trimesh.boolean.difference([b, a], engine='manifold')

        vol_amb = abs(a_minus_b.volume) if a_minus_b is not None and len(a_minus_b.faces) > 0 else 0.0
        vol_bma = abs(b_minus_a.volume) if b_minus_a is not None and len(b_minus_a.faces) > 0 else 0.0

        return vol_amb + vol_bma, abs(a.volume), abs(b.volume)
    except Exception as e:
        return None, None, str(e)

# ─────────────────────────────────────────────────────────────
# RATING HELPER
# ─────────────────────────────────────────────────────────────

def rate(value, t_excellent, t_good, t_fair):
    if value < t_excellent: return f"{GREEN}EXCELLENT{RESET}"
    elif value < t_good:    return f"{GREEN}GOOD{RESET}"
    elif value < t_fair:    return f"{YELLOW}FAIR{RESET}"
    else:                   return f"{RED}POOR{RESET}"

# ─────────────────────────────────────────────────────────────
# PER-PART REPORT
# ─────────────────────────────────────────────────────────────

def analyse_pair(label, orig_path, rebuilt_path):
    print(f"\n{BOLD}{CYAN}{'═'*65}{RESET}")
    print(f"{BOLD}{CYAN}  {label}{RESET}")
    print(f"{CYAN}{'═'*65}{RESET}")

    for p, name in [(orig_path, 'ORIGINAL'), (rebuilt_path, 'REBUILT')]:
        if not os.path.exists(p):
            print(f"  {RED}✗ FILE NOT FOUND [{name}]: {p}{RESET}")
            return

    # ── 1. File info ──────────────────────────────────────────
    print(f"\n  {BOLD}[ File Info ]{RESET}")
    print(f"  {'':30} {'ORIGINAL':>14}  {'REBUILT':>14}")
    print(f"  {'─'*62}")
    print(f"  {'File size (bytes)':<30} {os.path.getsize(orig_path):>14,}  {os.path.getsize(rebuilt_path):>14,}")
    print(f"  {'Triangle count':<30} {triangle_count(orig_path):>14,}  {triangle_count(rebuilt_path):>14,}")

    # ── 2. Volume ─────────────────────────────────────────────
    orig_vol    = volume_from_stl(orig_path)
    rebuilt_vol = volume_from_stl(rebuilt_path)
    vol_diff    = abs(orig_vol - rebuilt_vol)
    vol_pct     = vol_diff / orig_vol * 100 if orig_vol > 0 else 0

    print(f"\n  {BOLD}[ Volume Analysis ]{RESET}")
    print(f"  {'':30} {'ORIGINAL':>14}  {'REBUILT':>14}  {'DIFF':>10}")
    print(f"  {'─'*72}")
    print(f"  {'Volume (mm³)':<30} {orig_vol:>14.2f}  {rebuilt_vol:>14.2f}  {vol_diff:>8.2f}")
    print(f"  {'Volume error':<30} {'':>14}  {'':>14}  {vol_pct:>8.3f}%")
    print(f"  {'Volume rating':<30} {'':>14}  {'':>14}  {rate(vol_pct, 0.5, 2.0, 5.0)}")

    # ── 3. Surface area ───────────────────────────────────────
    orig_sa    = surface_area_from_stl(orig_path)
    rebuilt_sa = surface_area_from_stl(rebuilt_path)
    sa_diff    = abs(orig_sa - rebuilt_sa)
    sa_pct     = sa_diff / orig_sa * 100 if orig_sa > 0 else 0

    print(f"\n  {BOLD}[ Surface Area Analysis ]{RESET}")
    print(f"  {'':30} {'ORIGINAL':>14}  {'REBUILT':>14}  {'DIFF':>10}")
    print(f"  {'─'*72}")
    print(f"  {'Surface area (mm²)':<30} {orig_sa:>14.2f}  {rebuilt_sa:>14.2f}  {sa_diff:>8.2f}")
    print(f"  {'Surface area error':<30} {'':>14}  {'':>14}  {sa_pct:>8.3f}%")
    print(f"  {'Surface area rating':<30} {'':>14}  {'':>14}  {rate(sa_pct, 0.5, 2.0, 5.0)}")

    # ── 4. Bounding box ───────────────────────────────────────
    omin, omax = bbox(orig_path)
    rmin, rmax = bbox(rebuilt_path)
    odims = omax - omin
    rdims = rmax - rmin

    print(f"\n  {BOLD}[ Bounding Box (mm) ]{RESET}")
    print(f"  {'':30} {'ORIGINAL':>14}  {'REBUILT':>14}  {'DIFF':>10}")
    print(f"  {'─'*72}")
    print(f"  {'X dimension':<30} {odims[0]:>14.3f}  {rdims[0]:>14.3f}  {abs(odims[0]-rdims[0]):>8.3f}")
    print(f"  {'Y dimension':<30} {odims[1]:>14.3f}  {rdims[1]:>14.3f}  {abs(odims[1]-rdims[1]):>8.3f}")
    print(f"  {'Z dimension':<30} {odims[2]:>14.3f}  {rdims[2]:>14.3f}  {abs(odims[2]-rdims[2]):>8.3f}")
    print(f"  {'X origin (world)':<30} {omin[0]:>14.3f}  {rmin[0]:>14.3f}  {abs(omin[0]-rmin[0]):>8.3f}")
    print(f"  {'Y origin (world)':<30} {omin[1]:>14.3f}  {rmin[1]:>14.3f}  {abs(omin[1]-rmin[1]):>8.3f}")
    print(f"  {'Z origin (world)':<30} {omin[2]:>14.3f}  {rmin[2]:>14.3f}  {abs(omin[2]-rmin[2]):>8.3f}")
    print(f"\n  {YELLOW}Note: world origin differences are expected.{RESET}")
    print(f"  {YELLOW}Shape metrics below use centre-alignment + best orientation.{RESET}")

    # ── 5. Hausdorff (orientation-aware) ─────────────────────
    print(f"\n  {BOLD}[ Surface Deviation — Hausdorff Distance ]{RESET}")
    print(f"  Searching 24 orientations + computing...", end='', flush=True)
    hd   = hausdorff_distance(orig_path, rebuilt_path)
    hd_r = rate(hd, 0.1, 0.5, 1.0)
    print(f"\r  {'Max surface deviation (mm)':<30} {hd:>14.4f}")
    print(f"  {'Hausdorff rating':<30} {hd_r}")

    # ── 6. Symmetric difference ───────────────────────────────
    print(f"\n  {BOLD}[ Symmetric Difference Error ]{RESET}")
    sd_pct = None

    if HAS_TRIMESH:
        print(f"  Searching 24 orientations + computing...", end='', flush=True)
        sym_diff, a_vol, result = symmetric_difference(orig_path, rebuilt_path)
        if sym_diff is not None:
            sd_pct = sym_diff / a_vol * 100 if a_vol and a_vol > 0 else 0
            sd_r   = rate(sd_pct, 0.5, 2.0, 5.0)
            print(f"\r  {'Method':<30} {'exact boolean (manifold3d)'}")
            print(f"  {'Sym-diff volume (mm³)':<30} {sym_diff:>14.3f}")
            print(f"  {'Sym-diff as % of original':<30} {sd_pct:>13.3f}%")
            print(f"  {'Symmetric difference rating':<30} {sd_r}")
        else:
            print(f"\r  {YELLOW}Skipped: {result}{RESET}")
            print(f"  {YELLOW}(open-shell meshes cannot be used for boolean ops){RESET}")
    else:
        print(f"  {YELLOW}trimesh not installed — run: pip3 install trimesh manifold3d{RESET}")

    # ── 7. Overall verdict ────────────────────────────────────
    print(f"\n  {BOLD}[ Overall Verdict ]{RESET}")
    print(f"  {'─'*62}")

    metrics = {
        'Volume error':          (vol_pct, 2.0),
        'Surface area error':    (sa_pct,  2.0),
        'Max surface deviation': (hd,      0.5),
    }
    if sd_pct is not None:
        metrics['Symmetric diff error'] = (sd_pct, 2.0)

    passes = sum(1 for val, thresh in metrics.values() if val < thresh)
    total  = len(metrics)

    for name, (val, thresh) in metrics.items():
        unit = "mm" if name == 'Max surface deviation' else "%"
        tick = f"{GREEN}✓{RESET}" if val < thresh else f"{RED}✗{RESET}"
        print(f"  {tick}  {name:<32} {val:>8.3f}{unit}")

    print(f"  {'─'*62}")
    if passes == total:
        verdict = f"{GREEN}{BOLD}✓ PASS — All metrics within tolerance{RESET}"
    elif passes >= total - 1:
        verdict = f"{YELLOW}{BOLD}~ MARGINAL — Minor discrepancies detected{RESET}"
    else:
        verdict = f"{RED}{BOLD}✗ FAIL — Significant differences found{RESET}"
    print(f"  {verdict}  ({passes}/{total} metrics pass)")

